# Sentinel environment. Copy to a file your shell sources (NOT committed) and
# fill in your own values. The app reads process.env only; it never parses a
# .env file itself. Nothing here ships with the repo.

# ── Data providers (bring your own keys) ───────────────────────────────
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
PUMPPORTAL_API_KEY=            # PumpPortal API key (trade stream)
HELIUS_API_KEY=               # Helius — on-chain enrichment
SOLANA_RPC_URL=               # keyed Solana RPC (e.g. your Helius endpoint)
ANTHROPIC_API_KEY=            # Claude — BUY/SKIP decisions
MORALIS_API_KEY=              # optional secondary enrichment provider

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=                 # Postgres connection string (e.g. Supabase)

# ── API / dashboard (optional; defaults keep it loopback-only) ─────────
PORT=                         # injected by the host (Railway etc.); default 3001
API_HOST=                     # 127.0.0.1 default; set 0.0.0.0 to expose
API_TOKEN=                    # when set, gates the REST API + websocket
DASHBOARD_ORIGIN=             # extra CORS origin (deployed dashboard URL)

# ── Live trading wallet — DO NOT SET unless you have manually enabled ──
# ── LIVE_TRADING in risk/guards.ts. Paper mode never reads this. Use a ─
# ── key you generated yourself, offline. Never a service-generated one. ─
SOLANA_PRIVATE_KEY=

# ── Strategy tuning (optional; unset = SPEC-strict defaults) ───────────
# FILTER_MIN_AGE_SEC=1200
# FILTER_CURVE_MIN=55
# FILTER_CURVE_MAX=85
# FILTER_TOP10_MAX=25
# FILTER_DEV_SOLD_MAX=50
# EXIT_PROFILE=default        # default | scalp
# EXIT_TP_TRIGGER=
# EXIT_TP_SELL=
# EXIT_TRAIL=
# EXIT_HARD_STOP=
# EXIT_TIME_STOP_SEC=
